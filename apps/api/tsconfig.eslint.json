{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
      "rootDir": ".",
      "noEmit": true,
      "strictNullChecks": true,
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "allowJs": true,
      "skipLibCheck": true,
      "types": ["node"]
    },
    "include": [
      "src/**/*.ts",
      "test/**/*.ts",
      "vitest.config.ts",
      "vitest.integration.config.ts",
    ],
    "exclude": [
      "dist",
      "node_modules"
    ]
}