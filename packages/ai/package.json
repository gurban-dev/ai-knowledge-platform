{
  "name": "@akp/ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@akp/core": "workspace:*"
  },
  "devDependencies": {
    "@akp/eslint-config": "workspace:*",
    "@akp/tsconfig": "workspace:*",
    "@types/node": "^20.14.10",
    "eslint": "^9.10.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
