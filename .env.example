# ---------------------------------------------------------------------------
# AI Knowledge Platform — environment template
# Copy to `.env` and fill in. NEVER commit a real .env.
# All variables are validated at boot by @akp/config (fail-fast).
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# --- API server ---
API_HOST=0.0.0.0
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000
WEB_PUBLIC_URL=http://localhost:3000

# --- Database (Postgres + pgvector) ---
DATABASE_URL=postgresql://akp:akp_dev_password@localhost:5432/akp?schema=public
TEST_DATABASE_URL=postgresql://akp:akp_dev_password@localhost:5432/akp_test?schema=public

# --- Redis (cache, rate limiting, BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth / JWT ---
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars-long
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-chars-long
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_ISSUER=akp
JWT_AUDIENCE=akp-api
PASSWORD_HASH_MEMORY_COST=19456

# --- Field encryption (AES-256-GCM). keyId:base64(32-byte-key) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_ACTIVE_KEY_ID=dev
ENCRYPTION_KEYS=dev:YWtwLWRldi1lbmNyeXB0aW9uLWtleS0wMDAwMDAwMDE=

# --- MFA ---
MFA_ISSUER=AKP
SECURITY_REQUIRE_MFA=false
SECURITY_ALLOW_SSO=true
SECURITY_API_KEY_RETENTION_DAYS=365

# --- AI providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536
CHAT_MODEL=gpt-4o
AI_FORCE_FAKE=false
RETRIEVAL_VECTOR_K=40
RETRIEVAL_LEXICAL_K=40
RETRIEVAL_RERANK_K=8
RETRIEVAL_MIN_SCORE=0.12
GROUNDING_MIN_CONFIDENCE=0.35

# --- Object storage ---
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=.data/objects
STORAGE_BUCKET=akp-documents
STORAGE_GCS_ACCESS_TOKEN=

# --- Queues / workers ---
QUEUE_PREFIX=akp
INGEST_CONCURRENCY=4
WEBHOOK_CONCURRENCY=8

# --- Webhooks / idempotency / retention ---
WEBHOOK_MAX_ATTEMPTS=6
WEBHOOK_TIMEOUT_MS=5000
IDEMPOTENCY_TTL_SECONDS=86400
RETENTION_SWEEP_ENABLED=false

# --- Billing (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- MCP server ---
MCP_HOST=0.0.0.0
MCP_PORT=4100

# --- Observability ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=akp-api
SENTRY_DSN=
SLO_AVAILABILITY_TARGET=99.9%
SLO_LATENCY_BUDGET_MS=750
SLO_ERROR_BUDGET_MINUTES=43
SLO_BURN_ALERT=burn-rate > 14.4 over 1h

# --- Operations / DR reporting ---
INCIDENT_CHANNEL=#akp-incident-response
INCIDENT_RUNBOOK_URL=https://example.com/runbooks/akp

# --- Rate limiting ---
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=60000
API_KEY_RATE_LIMIT_PER_MINUTE=120

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
