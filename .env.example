# ---------------------------------------------------------------------------
# AI Knowledge Platform — environment template
# Copy to `.env` and fill in. NEVER commit a real .env.
# All variables are validated at boot by @akp/config (fail-fast).
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# --- API server ---
API_HOST=0.0.0.0
API_PORT=4000
# Public URL the API is reachable at (used for links, OAuth callbacks, OpenAPI servers)
API_PUBLIC_URL=http://localhost:4000
# Comma-separated list of allowed browser origins for CORS
CORS_ORIGINS=http://localhost:3000

# --- Database (Postgres + pgvector) ---
# Matches docker-compose defaults
DATABASE_URL=postgresql://akp:akp_dev_password@localhost:5432/akp?schema=public
# Separate URL used by integration tests (created/reset by the test harness)
TEST_DATABASE_URL=postgresql://akp:akp_dev_password@localhost:5432/akp_test?schema=public

# --- Redis (cache, rate limiting, BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth / JWT ---
# Use `openssl rand -base64 48` for each secret in real environments.
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars-long
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-chars-long
JWT_ACCESS_TTL=900          # seconds (15 min)
JWT_REFRESH_TTL=2592000     # seconds (30 days)
JWT_ISSUER=akp
JWT_AUDIENCE=akp-api
# Argon2id password hashing memory cost (KiB). Lower for dev, raise in prod.
PASSWORD_HASH_MEMORY_COST=19456

# --- AI providers (Phase 4+) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536
CHAT_MODEL=gpt-4o

# --- Observability ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=akp-api
SENTRY_DSN=

# --- Rate limiting (defaults; per-route overrides in code) ---
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=60000     # ms
